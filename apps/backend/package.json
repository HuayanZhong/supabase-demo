{
  "name": "backend",
  "version": "0.0.1",
  "private": true,
  "description": "",
  "license": "UNLICENSED",
  "author": "",
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "dev:debug": "nest start --debug --watch",
    "prod": "node dist/main",
    "lint": "oxlint",
    "format": "oxfmt --check .",
    "format:fix": "oxfmt .",
    "check-types": "tsc --noEmit",
    "generate:openapi": "node -e \"const h=require('http');h.get('http://localhost:4000/api/docs-json',r=>{let d='';r.on('data',c=>d+=c);r.on('end',()=>{require('fs').writeFileSync(require('path').resolve(process.cwd(),'../../openapi.json'),d,'utf-8');const{execSync}=require('child_process');execSync('node scripts/add-openapi-security.cjs',{cwd:require('path').resolve(process.cwd(),'../..'),stdio:'inherit'});process.exit(0)});r.on('error',e=>{console.error(e);process.exit(1)})})\""
  },
  "dependencies": {
    "@faker-js/faker": "catalog:backend",
    "@mikro-orm/core": "catalog:backend",
    "@mikro-orm/decorators": "catalog:backend",
    "@mikro-orm/migrations": "catalog:backend",
    "@mikro-orm/nestjs": "catalog:backend",
    "@mikro-orm/postgresql": "catalog:backend",
    "@mikro-orm/reflection": "catalog:backend",
    "@mikro-orm/seeder": "catalog:backend",
    "@nestjs/cache-manager": "catalog:backend",
    "@nestjs/common": "catalog:backend",
    "@nestjs/config": "catalog:backend",
    "@nestjs/core": "catalog:backend",
    "@nestjs/mapped-types": "*",
    "@nestjs/platform-express": "catalog:backend",
    "@nestjs/swagger": "catalog:backend",
    "@nestjs/throttler": "catalog:backend",
    "@supabase/ai-runtime": "workspace:*",
    "@supabase/config": "workspace:*",
    "@supabase/supabase-js": "catalog:dev",
    "cache-manager": "catalog:backend",
    "class-transformer": "catalog:backend",
    "class-validator": "catalog:backend",
    "dotenv": "^17.4.2",
    "helmet": "catalog:backend",
    "nestjs-pino": "catalog:backend",
    "pino": "catalog:logger",
    "pino-http": "catalog:backend",
    "reflect-metadata": "catalog:backend",
    "rxjs": "catalog:backend"
  },
  "devDependencies": {
    "@mikro-orm/cli": "catalog:backend",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@supabase/lint-config": "workspace:*",
    "@types/express": "^5.0.0",
    "@types/node": "catalog:dev",
    "oxfmt": "catalog:dev",
    "oxlint": "catalog:dev",
    "pino-pretty": "catalog:logger",
    "source-map-support": "^0.5.21",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "catalog:backend",
    "typescript": "catalog:dev"
  },
  "packageManager": "pnpm@11.4.0"
}
