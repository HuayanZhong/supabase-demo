# EditorConfig 跨编辑器统一编码风格
# https://editorconfig.org

root = true

# 全局默认：UTF-8、LF 换行、空格缩进 2 格、末行换行、清理尾部空格
[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

# Markdown：保留尾部空格，避免破坏表格/换行语法
[*.md]
trim_trailing_whitespace = false

# YAML：保持 2 格缩进
[*.{yml,yaml}]
indent_size = 2

# Makefile：必须用 Tab
[Makefile]
indent_style = tab

# JSON 配置文件：保持 2 格缩进
[{package.json,.lintstagedrc.json,.oxfmtrc.json}]
indent_size = 2
