                "schema": {
                  "type": "object",
                  "properties": {
                    "code": { "type": "number", "example": 200 },
                    "data": { "type": "array", "items": { "$ref": "#/components/schemas/Quote" } },
                    "msg": { "type": "string", "example": "success" }
                  },
                  "required": ["code", "data", "msg"]
                }
              }
            }
          }
        },
        "summary": "获取所有名言",
        "tags": ["名言"]
