    "/api/health": {
      "get": {
        "operationId": "HealthController_check",
        "parameters": [],
        "responses": {
          "200": {
            "description": "服务健康",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": { "type": "number", "example": 200 },
                    "data": {
                      "type": "object",
                      "properties": {
                        "status": { "type": "string", "example": "healthy" },
                        "timestamp": { "type": "string", "example": "2026-07-18T09:00:00.000Z" },
                        "checks": {
                          "type": "object",
                          "properties": { "database": { "type": "string", "example": "up" } }
                        }
                      }
                    },
                    "msg": { "type": "string", "example": "success" }
                  }
                }
              }
            }
          },
          "503": {
            "description": "服务异常",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": { "type": "number", "example": 503 },
                    "data": { "type": "null", "example": null },
                    "msg": { "type": "string", "example": "服务异常" }
                  },
                  "required": ["code", "data", "msg"]
                }
              }
            }
          }
        },
        "summary": "健康检查",
        "tags": ["健康检查"]
      }
    },
    "/api/v1/auth/me": {
      "get": {
        "operationId": "AuthController_getProfile_v1",
        "parameters": [],
        "responses": {
          "200": {
            "description": "当前用户信息",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": { "type": "string", "example": "uuid" },
                    "email": { "type": "string", "example": "user@example.com" },
                    "created_at": { "type": "string" }
                  }
                }
              }
            }
          }
        },
        "summary": "获取当前登录用户信息",
        "tags": ["认证"]
      }
    }
  },
  "info": {
    "title": "Supabase Demo API",
    "description": "后端 API 文档",
    "version": "1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "schemas": {
      "Location": {
        "type": "object",
        "properties": {
          "id": { "type": "number", "description": "位置 ID" },
          "qweatherId": {
            "type": "string",
            "description": "和风天气 LocationID",
            "example": "101010100"
          },
          "name": { "type": "string", "description": "位置名称", "example": "东城" },
          "lat": { "type": "number", "description": "纬度", "example": 39.9163 },
          "lon": { "type": "number", "description": "经度", "example": 116.3972 },
          "adm2": { "type": "string", "description": "上级行政区划", "example": "北京" },
          "adm1": { "type": "string", "description": "一级行政区域", "example": "北京市" },
          "country": { "type": "string", "description": "国家", "example": "中国" },
          "tz": { "type": "string", "description": "时区", "example": "Asia/Shanghai" },
          "utcOffset": { "type": "string", "description": "UTC 时间偏移", "example": "+08:00" },
          "isDst": { "type": "boolean", "description": "是否夏令时", "default": false },
          "type": { "type": "string", "description": "位置类型", "example": "city" },
          "rank": { "type": "number", "description": "位置评分" },
          "fxLink": { "type": "string", "description": "天气预报链接" },
          "createdAt": { "format": "date-time", "type": "string", "description": "创建时间" },
          "updatedAt": { "format": "date-time", "type": "string", "description": "更新时间" }
        },
        "required": ["id", "qweatherId", "name", "lat", "lon", "createdAt", "updatedAt"]
      },
      "CreateLocationInputDto": {
        "type": "object",
        "properties": {
          "lat": {
            "type": "number",
            "description": "纬度",
            "example": 39.9163,
            "minimum": -90,
            "maximum": 90
          },
          "lon": {
            "type": "number",
            "description": "经度",
            "example": 116.3972,
            "minimum": -180,
            "maximum": 180
          }
        },
        "required": ["lat", "lon"]
      },
      "UpdateLocationDto": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "description": "位置名称", "example": "东城" },
          "adm2": { "type": "string", "description": "上级行政区划", "example": "北京" },
          "adm1": { "type": "string", "description": "一级行政区域", "example": "北京市" }
        }
      },
      "WeatherVo": {
        "type": "object",
        "properties": {
          "city": { "type": "string", "description": "城市名", "example": "北京" },
          "temp": { "type": "number", "description": "当前温度（摄氏度）", "example": 25 },
          "tempLow": { "type": "number", "description": "最低温度（摄氏度）", "example": 20 },
          "tempHigh": { "type": "number", "description": "最高温度（摄氏度）", "example": 28 },
          "condition": { "type": "string", "description": "天气状况描述", "example": "多云" },
          "icon": { "type": "string", "description": "图标名", "example": "i-lucide-cloud-sun" },
          "humidity": { "type": "number", "description": "相对湿度（百分比）", "example": 65 },
          "wind": { "type": "string", "description": "风速描述", "example": "东南风 12km/h" },
          "uvIndex": { "type": "number", "description": "紫外线指数", "example": 3 }
        },
        "required": [
          "city",
          "temp",
          "tempLow",
          "tempHigh",
          "condition",
          "icon",
          "humidity",
          "wind",
          "uvIndex"
        ]
      },
      "Quote": {
        "type": "object",
        "properties": {
          "id": { "type": "number", "description": "名言 ID" },
          "content": { "type": "string", "description": "名言内容", "example": "知识就是力量" },
          "author": { "type": "string", "description": "作者", "example": "培根" },
          "createdAt": { "format": "date-time", "type": "string", "description": "创建时间" },
          "updatedAt": { "format": "date-time", "type": "string", "description": "更新时间" }
        },
        "required": ["id", "content", "createdAt", "updatedAt"]
      },
      "UpdateQuoteDto": { "type": "object", "properties": {} }
    }
  }
}
