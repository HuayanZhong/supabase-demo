{
  "openapi": "3.0.0",
  "paths": {
    "/api/v1/locations/search": {
      "get": {
        "operationId": "LocationsController_search_v1",
        "parameters": [
          {
            "name": "keyword",
            "required": true,
            "in": "query",
            "description": "城市名/关键词",
            "schema": { "example": "北京", "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "搜索成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": { "type": "number", "example": 200 },
                    "data": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/Location" }
                    },
                    "msg": { "type": "string", "example": "success" }
                  },
                  "required": ["code", "data", "msg"]
                }
              }
            }
          }
        },
        "summary": "搜索城市",
        "tags": ["位置"]
      }
    },
    "/api/v1/locations": {
      "post": {
        "operationId": "LocationsController_create_v1",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateLocationInputDto" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "创建成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": { "type": "number", "example": 201 },
                    "data": { "$ref": "#/components/schemas/Location" },
                    "msg": { "type": "string", "example": "success" }
                  },
                  "required": ["code", "data", "msg"]
                }
              }
            }
          },
          "404": {
            "description": "经纬度未找到对应城市",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": { "type": "number", "example": 404 },
                    "data": { "type": "null", "example": null },
                    "msg": { "type": "string", "example": "经纬度未找到对应城市" }
                  },
                  "required": ["code", "data", "msg"]
                }
              }
            }
          },
          "502": {
            "description": "逆地理编码服务错误",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": { "type": "number", "example": 502 },
                    "data": { "type": "null", "example": null },
                    "msg": { "type": "string", "example": "逆地理编码服务错误" }
                  },
                  "required": ["code", "data", "msg"]
                }
              }
            }
          }
        },
        "summary": "创建位置（经纬度 + 逆地理编码）",
        "tags": ["位置"]
      },
      "get": {
        "operationId": "LocationsController_findAll_v1",
        "parameters": [],
        "responses": {
          "200": {
            "description": "获取成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": { "type": "number", "example": 200 },
                    "data": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/Location" }
                    },
                    "msg": { "type": "string", "example": "success" }
                  },
                  "required": ["code", "data", "msg"]
                }
              }
            }
          }
        },
        "summary": "获取所有位置",
        "tags": ["位置"]
      }
    },
    "/api/v1/locations/{id}": {
      "get": {
        "operationId": "LocationsController_findOne_v1",
        "parameters": [
          { "name": "id", "required": true, "in": "path", "schema": { "type": "number" } }
        ],
        "responses": {
          "200": {
            "description": "获取成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": { "type": "number", "example": 200 },
                    "data": { "$ref": "#/components/schemas/Location" },
                    "msg": { "type": "string", "example": "success" }
                  },
                  "required": ["code", "data", "msg"]
                }
              }
            }
          },
          "404": {
            "description": "位置不存在",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": { "type": "number", "example": 404 },
                    "data": { "type": "null", "example": null },
                    "msg": { "type": "string", "example": "位置不存在" }
                  },
                  "required": ["code", "data", "msg"]
                }
              }
            }
          }
        },
        "summary": "获取单个位置",
        "tags": ["位置"]
      },
      "patch": {
        "operationId": "LocationsController_update_v1",
        "parameters": [
          { "name": "id", "required": true, "in": "path", "schema": { "type": "number" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/UpdateLocationDto" } }
          }
        },
        "responses": {
          "200": {
            "description": "更新成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": { "type": "number", "example": 200 },
                    "data": { "$ref": "#/components/schemas/Location" },
                    "msg": { "type": "string", "example": "success" }
                  },
                  "required": ["code", "data", "msg"]
                }
              }
            }
          },
          "404": {
            "description": "位置不存在",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": { "type": "number", "example": 404 },
                    "data": { "type": "null", "example": null },
                    "msg": { "type": "string", "example": "位置不存在" }
                  },
                  "required": ["code", "data", "msg"]
                }
              }
            }
          }
        },
        "summary": "更新位置",
        "tags": ["位置"]
      },
      "delete": {
        "operationId": "LocationsController_remove_v1",
        "parameters": [
          { "name": "id", "required": true, "in": "path", "schema": { "type": "number" } }
        ],
        "responses": {
          "200": { "description": "删除成功" },
          "404": {
            "description": "位置不存在",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": { "type": "number", "example": 404 },
                    "data": { "type": "null", "example": null },
                    "msg": { "type": "string", "example": "位置不存在" }
                  },
                  "required": ["code", "data", "msg"]
                }
              }
            }
          }
        },
        "summary": "删除位置",
        "tags": ["位置"]
      }
    },
    "/api/v1/weathers": {
      "get": {
        "operationId": "WeathersController_getWeather_v1",
        "parameters": [
          {
            "name": "locationId",
            "required": true,
            "in": "query",
            "description": "和风天气 LocationID",
            "schema": { "example": "101010100", "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "获取成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": { "type": "number", "example": 200 },
                    "data": { "$ref": "#/components/schemas/WeatherVo" },
                    "msg": { "type": "string", "example": "success" }
                  },
                  "required": ["code", "data", "msg"]
                }
              }
            }
          },
          "400": {
            "description": "locationId 参数缺失",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": { "type": "number", "example": 400 },
                    "data": { "type": "null", "example": null },
                    "msg": { "type": "string", "example": "locationId 参数缺失" }
                  },
                  "required": ["code", "data", "msg"]
                }
              }
            }
          },
          "404": {
            "description": "位置不存在",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": { "type": "number", "example": 404 },
                    "data": { "type": "null", "example": null },
                    "msg": { "type": "string", "example": "位置不存在" }
                  },
                  "required": ["code", "data", "msg"]
                }
              }
            }
          },
          "502": {
            "description": "天气服务错误",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": { "type": "number", "example": 502 },
                    "data": { "type": "null", "example": null },
                    "msg": { "type": "string", "example": "天气服务错误" }
                  },
                  "required": ["code", "data", "msg"]
                }
              }
            }
          }
        },
        "summary": "获取实时天气",
        "tags": ["天气"]
      }
    },
    "/api/v1/quotes": {
