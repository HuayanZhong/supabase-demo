{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "powershell -ExecutionPolicy Bypass -File .trae/hooks/inject-agent-roles.ps1"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "powershell -ExecutionPolicy Bypass -File .trae/hooks/inject-agent-routing.ps1"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "DeleteFile|Edit|Write",
        "hooks": [
          {
            "command": "powershell -ExecutionPolicy Bypass -File .trae/hooks/protect-mcp-json.ps1"
          },
          {
            "command": "powershell -ExecutionPolicy Bypass -File .trae/hooks/enforce-code-standards.ps1"
          }
        ]
      },
      {
        "matcher": "mcp_.*__execute_sql",
        "hooks": [
          {
            "command": "powershell -ExecutionPolicy Bypass -File .trae/hooks/protect-sql.ps1"
          }
        ]
      },
      {
        "matcher": "mcp_chrome-devtools__.*",
        "hooks": [
          {
            "command": "powershell -ExecutionPolicy Bypass -File .trae/hooks/inject-credentials.ps1"
          }
        ]
      },
      {
        "matcher": "mcp_chrome-devtools__.*|mcp_supabase__.*|mcp_Filesystem__.*|mcp_Sequential_Thinking__.*|mcp_context7__.*|mcp_tavily_search__.*|mcp_nuxt-ui__.*|mcp_github__.*|mcp_windows-cli__.*|mcp_autoglm.*|mcp_aminer.*|integrated_code_mode__.*",
        "hooks": [
          {
            "command": "powershell -ExecutionPolicy Bypass -File .trae/hooks/inject-tool-rules.ps1"
          }
        ]
      },
      {
        "matcher": "RunCommand",
        "hooks": [
          {
            "command": "powershell -ExecutionPolicy Bypass -File .trae/hooks/validate-commit-msg.ps1"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "command": "powershell -ExecutionPolicy Bypass -File .trae/hooks/post-tool-verify.ps1"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "powershell -ExecutionPolicy Bypass -File .trae/hooks/inject-quality-rules.ps1"
          }
        ]
      }
    ]
  }
}
