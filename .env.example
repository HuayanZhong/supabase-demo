# ===========================================
# Supabase Demo — 环境变量模板
# ===========================================
# 复制为对应环境的 .env 文件并填入真实值
# 不要直接修改此文件
#
# 后端变量 → 填入 apps/backend/.env
# 前端变量 → 填入 apps/frontend/.env

# --- 后端 (apps/backend) ---
# PostgreSQL 连接串
DATABASE_URL=postgresql://user:password@localhost:5432/postgres

# 后端服务端口（默认 4000）
PORT=4000

# Supabase 项目地址
SUPABASE_URL=https://your-project.supabase.co

# --- 前端 (apps/frontend, NUXT_ 前缀自动注入 runtimeConfig) ---
# 前端 Supabase URL（与 SUPABASE_URL 相同）
NUXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# 前端 Supabase 匿名 Key（Settings → API → anon / publishable key）
NUXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-anon-key
