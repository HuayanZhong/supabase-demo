# ===========================================
# Supabase Demo — 环境变量模板
# ===========================================
# 复制为对应环境的 .env 文件并填入真实值
# 不要直接修改此文件
#
# 后端变量 → 填入 apps/backend/.env
# 前端变量 → 填入 apps/frontend/.env

# --- 后端 (apps/backend) ---
# PostgreSQL 连接串
DATABASE_URL=postgresql://user:password@localhost:5432/postgres

# 后端服务端口（默认 4000）
PORT=4000

# 和风天气 API Host（控制台 → 设置 → API Host）
WEATHER_API_HOST=your-api-host.qweatherapi.com
# 和风天气 JWT 私钥（Ed25519 PEM）
WEATHER_JWT_PRIVATE_KEY=your-ed25519-private-key-pem
# 和风天气 JWT 凭据 ID（控制台 → 项目管理 → 凭据）
WEATHER_JWT_KID=your-credential-id
# 和风天气 JWT 项目 ID（控制台 → 项目管理 → 项目）
WEATHER_JWT_SUB=your-project-id

# 运行环境（development / production / test）
# TODO(责任人): 补充默认值
NODE_ENV=development

# Supabase 项目地址
SUPABASE_URL=https://your-project.supabase.co

# Supabase 服务角色密钥（用于后端验证 JWT 和管理操作）
# TODO: 补充默认值
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# 后端 CORS 允许的前端域名
FRONTEND_URL=http://localhost:3000

# 迁移/DDL 专用连接串（与 DATABASE_URL 相同时可省略）
DIRECT_URL=postgresql://user:password@localhost:5432/postgres

# --- 前端 (apps/frontend, NUXT_ 前缀自动注入 runtimeConfig) ---
# 前端 Supabase URL（与 SUPABASE_URL 相同）
NUXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# 前端 Supabase 匿名 Key（Settings → API → anon / publishable key）
NUXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-anon-key

# 后端 API 地址（开发环境默认 http://localhost:4000/api）
NUXT_PUBLIC_API_BASE=http://localhost:4000/api
